<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Telegram Verification</title>
  <style>
    :root {
      --bg: #f4efe6;
      --panel: rgba(255,255,255,0.88);
      --ink: #152128;
      --muted: #57626b;
      --accent: #c4542d;
      --accent-dark: #963919;
      --border: rgba(21, 33, 40, 0.12);
      --success: #1f6f43;
      --error: #9f2d2d;
      --shadow: 0 24px 70px rgba(21, 33, 40, 0.12);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      font-family: Georgia, "Times New Roman", serif;
      color: var(--ink);
      background:
        radial-gradient(circle at top right, rgba(196, 84, 45, 0.18), transparent 30%),
        linear-gradient(135deg, #efe5d5 0%, #f9f5ee 45%, #e2ecee 100%);
      display: grid;
      place-items: center;
      padding: 24px;
    }
    main {
      width: min(100%, 760px);
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 28px;
      box-shadow: var(--shadow);
      padding: 32px;
      backdrop-filter: blur(12px);
    }
    h1 {
      margin: 0 0 12px;
      font-size: clamp(2rem, 4vw, 3.6rem);
      line-height: 0.95;
      letter-spacing: -0.04em;
    }
    p {
      margin: 0 0 16px;
      color: var(--muted);
      line-height: 1.6;
      font-size: 1rem;
    }
    .card {
      margin-top: 24px;
      padding: 20px;
      border-radius: 18px;
      background: rgba(255,255,255,0.75);
      border: 1px solid rgba(21, 33, 40, 0.08);
    }
    .label {
      display: block;
      margin-bottom: 8px;
      color: var(--muted);
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    code, pre {
      font-family: "SFMono-Regular", Menlo, Consolas, monospace;
      font-size: 0.95rem;
    }
    pre {
      margin: 0;
      padding: 14px;
      overflow-x: auto;
      border-radius: 14px;
      background: #18242a;
      color: #fef8ee;
    }
    button {
      margin-top: 24px;
      border: 0;
      border-radius: 999px;
      background: var(--accent);
      color: white;
      padding: 14px 22px;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      transition: transform 160ms ease, background 160ms ease;
    }
    button:hover { background: var(--accent-dark); transform: translateY(-1px); }
    button:disabled { opacity: 0.65; cursor: wait; transform: none; }
    .status {
      min-height: 1.5rem;
      margin-top: 16px;
      font-weight: 600;
    }
    .status.error { color: var(--error); }
    .status.success { color: var(--success); }
    .api-key {
      margin-top: 16px;
      display: none;
    }
    .api-key.visible { display: block; }
    @media (max-width: 640px) {
      main { padding: 24px; border-radius: 22px; }
      h1 { font-size: 2.4rem; }
    }
  </style>
</head>
<body>
  <main>
    <h1>Verify in Telegram, then mint your API key.</h1>
    <p>The page will generate a verification token automatically, then you can post the command in the configured Telegram channel and return here to request your API key.</p>
    <div id="verification-panel" style="display:none;">
      <div class="card">
      <span class="label">Verification Command</span>
      <pre id="command-value"></pre>
      </div>
      <div class="card">
      <span class="label">Verification Token</span>
      <pre id="token-value"></pre>
      </div>
    </div>
    <button id="get-key-button" type="button">Get API Key</button>
    <div id="status" class="status" aria-live="polite"></div>
    <div id="api-key" class="api-key card">
      <span class="label">Issued API Key</span>
      <pre id="api-key-value"></pre>
    </div>
  </main>
  <script>
    const startEndpoint = {{.StartEndpoint}};
    const statusEndpoint = {{.StatusEndpoint}};
    const keyEndpoint = {{.KeyEndpoint}};
    const statusEl = document.getElementById("status");
    const buttonEl = document.getElementById("get-key-button");
    const verificationPanelEl = document.getElementById("verification-panel");
    const commandValueEl = document.getElementById("command-value");
    const tokenValueEl = document.getElementById("token-value");
    const apiKeyWrapEl = document.getElementById("api-key");
    const apiKeyValueEl = document.getElementById("api-key-value");
    let currentToken = "";
    let currentSessionToken = "";

    function setStatus(message, kind) {
      statusEl.textContent = message;
      statusEl.className = "status" + (kind ? " " + kind : "");
    }

    async function postJSON(url, body) {
      const response = await fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body)
      });
      const payload = await response.json().catch(() => null);
      if (!response.ok) {
        const error = new Error(payload && payload.message ? payload.message : "Request failed.");
        error.code = payload && payload.error ? payload.error : "request_failed";
        throw error;
      }
      return payload;
    }

    function setVerificationState(payload) {
      currentToken = payload.token;
      currentSessionToken = payload.session_token;
      commandValueEl.textContent = payload.command;
      tokenValueEl.textContent = payload.token;
      verificationPanelEl.style.display = "block";
      try {
        localStorage.setItem("rdai-current-token", currentToken);
        localStorage.setItem("rdai-session:" + currentToken, currentSessionToken);
      } catch (_) {}
    }

    function clearVerificationState() {
      const tokenToClear = currentToken;
      currentToken = "";
      currentSessionToken = "";
      commandValueEl.textContent = "";
      tokenValueEl.textContent = "";
      verificationPanelEl.style.display = "none";
      apiKeyValueEl.textContent = "";
      apiKeyWrapEl.classList.remove("visible");
      try {
        if (tokenToClear) {
          localStorage.removeItem("rdai-session:" + tokenToClear);
        }
        localStorage.removeItem("rdai-current-token");
      } catch (_) {}
    }

    function restoreVerificationState() {
      try {
        const token = localStorage.getItem("rdai-current-token") || "";
        const sessionToken = token ? (localStorage.getItem("rdai-session:" + token) || "") : "";
        if (!token || !sessionToken) {
          return;
        }
        setVerificationState({
          token,
          session_token: sessionToken,
          command: "/verify " + token
        });
      } catch (_) {}
    }

    function requestPayload() {
      let storedSessionToken = currentSessionToken;
      let storedToken = currentToken;
      try {
        storedToken = localStorage.getItem("rdai-current-token") || currentToken;
        storedSessionToken = storedToken ? (localStorage.getItem("rdai-session:" + storedToken) || currentSessionToken) : currentSessionToken;
      } catch (_) {}
      return { token: storedToken, session_token: storedSessionToken };
    }

    async function ensureVerificationStarted() {
      if (currentToken && currentSessionToken) {
        return;
      }

      try {
        const payload = await postJSON(startEndpoint, {});
        setVerificationState(payload);
        setStatus("Verification token is ready.", "success");
      } catch (error) {
        setStatus(error.message || "Failed to start verification.", "error");
      }
    }

    async function renewVerification(message) {
      clearVerificationState();
      await ensureVerificationStarted();
      if (message) {
        setStatus(message, "success");
      }
    }

    async function reconcileVerificationState() {
      restoreVerificationState();
      const payload = requestPayload();
      if (!payload.token || !payload.session_token) {
        await ensureVerificationStarted();
        return;
      }

      try {
        const statusPayload = await postJSON(statusEndpoint, payload);
        if (statusPayload.status === "verified") {
          setStatus("Verification is complete. You can request an API key.", "success");
        } else if (statusPayload.status === "issued") {
          await renewVerification("Previous verification was already used. A new token is ready.");
        }
      } catch (error) {
        if (error.code === "token_expired" || error.code === "token_not_found" || error.code === "session_not_found") {
          clearVerificationState();
          await ensureVerificationStarted();
          return;
        }
        setStatus(error.message || "Failed to restore verification state.", "error");
      }
    }

    buttonEl.addEventListener("click", async () => {
      buttonEl.disabled = true;
      try {
        const payload = requestPayload();
        if (!payload.token || !payload.session_token) {
          setStatus("Start verification before requesting an API key.", "error");
          return;
        }

        const statusPayload = await postJSON(statusEndpoint, payload);
        if (statusPayload.status === "issued") {
          if (apiKeyValueEl.textContent) {
            apiKeyWrapEl.classList.add("visible");
            setStatus("API key is already displayed on this page.", "success");
            return;
          }
          await renewVerification("Previous verification was already used. A new token is ready.");
          return;
        }

        if (statusPayload.status !== "verified") {
          setStatus(statusPayload.message || "Verification has not completed yet.", "error");
          return;
        }

        const keyPayload = await postJSON(keyEndpoint, payload);
        apiKeyValueEl.textContent = keyPayload.key;
        apiKeyWrapEl.classList.add("visible");
        setStatus("API key is ready.", "success");
      } catch (error) {
        if (error.code === "key_already_issued" && apiKeyValueEl.textContent) {
          apiKeyWrapEl.classList.add("visible");
          setStatus("API key is already displayed on this page.", "success");
          return;
        }
        setStatus(error.message || "Failed to request API key.", "error");
      } finally {
        buttonEl.disabled = false;
      }
    });

    reconcileVerificationState();
  </script>
</body>
</html>
